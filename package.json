{
  "name": "multicard-api",
  "displayName": "NetSuite multicard Project",
  "version": "1.0.0",
  "private": true,
  "description": "NetSuite TypeScript project for multicard - pequeño",
  "keywords": ["netsuite", "sdf", "suitescript", "typescript", "dx", "engineering"],
  "author": {
    "name": "Matt Plant",
    "url": "https://github.com/mattplant"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mattplant/netsuite-ts-sdf-template"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "node -e \"require('fs').rmSync('src/FileCabinet/SuiteScripts/multicard-api', { recursive: true, force: true })\"",
    "prebuild": "pnpm clean",
    "build": "biome format --write src/TypeScripts/multicard-api && tsc && node scripts/inject-headers.js && biome format --write src/FileCabinet/SuiteScripts/multicard-api",
    "watch": "tsc -w",
    "test": "jest",
    "suitecloud": "suitecloud",
    "setup": "suitecloud account:setup",
    "deploy": "pnpm build && suitecloud project:deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@hitc/netsuite-types": "^2025.1.0",
    "@oracle/suitecloud-cli": "^3.1.2",
    "@oracle/suitecloud-unit-testing": "^1.7.0",
    "jest": "^29.7.0",
    "typescript": "^5.4.0"
  }
}
