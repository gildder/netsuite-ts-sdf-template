{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "include": ["**/*.ts", "**/*.json", "src/FileCabinet/SuiteScripts/multicard-api/**/*.js"],
    "ignore": ["node_modules/**"]
  },
  "overrides": [
    {
      "include": ["src/FileCabinet/**"],
      "linter": { "enabled": false },
      "organizeImports": { "enabled": false }
    },
    {
      "include": ["src/TypeScripts/**"],
      "organizeImports": { "enabled": false }
    }
  ],
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": "error",
        "noDoubleEquals": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "trailingCommas": "all",
      "quoteStyle": "single",
      "bracketSpacing": true
    }
  }
}
